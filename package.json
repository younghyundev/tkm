{
  "name": "tkm",
  "version": "0.5.8",
  "description": "Claude Code Pokémon gamification plugin with token-to-XP progression and a Braille-first status line",
  "type": "module",
  "bin": {
    "tokenmon": "./src/cli/tokenmon.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "postinstall": "./bin/tsx-resolve.sh src/setup/postinstall.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "pngjs": "^7.0.0",
    "tsx": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pngjs": "^6.0.5",
    "typescript": "^5.5.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ThunderConch/tkm.git"
  },
  "homepage": "https://github.com/ThunderConch/tkm",
  "keywords": [
    "pokemon",
    "claude-code",
    "gamification",
    "productivity",
    "xp",
    "progression",
    "status-line",
    "braille"
  ]
}
